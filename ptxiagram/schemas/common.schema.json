{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-skills/pptx-diagram/schemas/common.schema.json",
  "title": "Shared definitions",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "point": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "nodeType": {
      "enum": ["client", "frontend", "neutral", "backend", "database", "cache", "queue", "external", "security", "decision", "active", "waiting", "success", "failure"]
    },
    "route": {
      "enum": ["straight", "drop", "elbow-right", "arc-over-top"]
    },
    "hexColor": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]{6}$"
    }
  }
}
